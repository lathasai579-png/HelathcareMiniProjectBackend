@model HealthcareApp.Web.ViewModels.AppointmentViewModel

<h2>Delete Appointment</h2>

<h4>Are you sure you want to delete this?</h4>

<div>
    <p><strong>Patient:</strong> @Model.PatientName</p>
    <p><strong>Doctor:</strong> @Model.DoctorName</p>
    <p><strong>Date:</strong> @Model.Date.ToShortDateString()</p>
    <p><strong>Time:</strong> @Model.TimeSlot</p>
</div>

<form asp-action="DeleteConfirmed">
    <input type="hidden" asp-for="AppointmentId" />
    <button class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>