@model HealthcareApp.Web.ViewModels.AppointmentViewModel

<h2>Edit Appointment</h2>

<form asp-action="Edit">

    <div asp-validation-summary="All" class="text-danger"></div>

    <input type="hidden" asp-for="AppointmentId" />

    <!-- Patient -->
    <div class="form-group">
        <label>Patient</label>
        <select asp-for="PatientId" asp-items="ViewBag.Patients" class="form-control"></select>
    </div>

    <!-- Doctor -->
    <div class="form-group">
        <label>Doctor</label>
        <select asp-for="DoctorId" asp-items="ViewBag.Doctors" class="form-control"></select>
    </div>

    <!-- Date -->
    <div class="form-group">
        <label>Date</label>
        <input asp-for="Date" type="date" class="form-control"
               min="@DateTime.Now.ToString("yyyy-MM-dd")" />
    </div>

    <!-- Time -->
    <div class="form-group">
        <label>Time Slot</label>
        <select asp-for="TimeSlot" class="form-control">
            @foreach (var t in ViewBag.TimeSlots)
            {
                <option value="@t">@t</option>
            }
        </select>
    </div>

    <!-- Status -->
    <div class="form-group">
        <label>Status</label>
        <select asp-for="Status" class="form-control">
            @foreach (var s in ViewBag.StatusList)
            {
                <option value="@s">@s</option>
            }
        </select>
    </div>

    <button class="btn btn-primary mt-2">Update</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Back</a>

</form>